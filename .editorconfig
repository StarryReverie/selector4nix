root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true
indent_style = space

[*.rs]
indent_size = 4

[*.nix]
indent_size = 2

[Makefile]
indent_style = tab
tab_width = 4

[*.md]
indent_size = 4
trim_trailing_whitespace = false

[{*.sh,*.zsh}]
indent_size = 2

[{*.json,*.jsonc,*.yml,*.yaml,*.toml}]
indent_size = 2

[*.kdl]
indent_size = 4
